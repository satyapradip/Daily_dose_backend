# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1

# ─────────────────────────────────────────────
# Database (PostgreSQL via Supabase + Prisma)
# Replace [YOUR-PASSWORD] with the DB password from Supabase Dashboard
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# ─────────────────────────────────────────────
# Supabase (Data API)
# Project URL and anon/public key from Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-prod
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────────
# Google Gemini AI (Google AI Studio)
# Get key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=1000
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Images are generated for free via Pollinations.ai (no API key needed)
# Voice (TTS) is generated via Google AI Studio (uses GEMINI_API_KEY above)

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# Images are generated for free via Pollinations.ai (no API key needed)

# ─────────────────────────────────────────────
# YouTube Data API v3 (trending videos)
# ─────────────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# ─────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────
ADMIN_SECRET_KEY=your-super-secret-admin-key-change-in-prod

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
